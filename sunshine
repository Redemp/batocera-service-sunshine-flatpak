#!/bin/bash
# Sunshine Flatpak user service for Batocera

export HOME=/userdata/system
export DISPLAY="${DISPLAY:-:0}"

APP_ID="dev.lizardbyte.app.Sunshine"
SERVICE_NAME="sunshine"
LOG_DIR="${HOME}/logs"
LOG_FILE="${LOG_DIR}/${SERVICE_NAME}.log"
WEB_UI_PORT="47990"

mkdir -p "${LOG_DIR}"

log() {
    printf '%s: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"
}

is_installed() {
    command -v flatpak >/dev/null 2>&1 && \
        flatpak info --system "${APP_ID}" >/dev/null 2>&1
}

port_in_use() {
    if command -v ss >/dev/null 2>&1; then
        ss -H -tln 2>/dev/null | awk -v p=":${WEB_UI_PORT}" '($4 ~ p"$") { found=1 } END { exit !found }'
        return $?
    fi
    if command -v netstat >/dev/null 2>&1; then
        netstat -tln 2>/dev/null | awk -v p=":${WEB_UI_PORT}" '($4 ~ p"$") { found=1 } END { exit !found }'
        return $?
    fi
    return 1
}

# True only for the Flatpak Sunshine app, never this service script
# (the service file is also named "sunshine", so pgrep -x is unsafe).
is_running() {
    if command -v flatpak >/dev/null 2>&1 && \
        flatpak ps --columns=application 2>/dev/null | grep -Fxq "${APP_ID}"; then
        return 0
    fi

    port_in_use
}

kill_leftover_sunshine() {
    local pid exe

    if command -v fuser >/dev/null 2>&1 && port_in_use; then
        fuser -k "${WEB_UI_PORT}/tcp" >/dev/null 2>&1 || true
    fi

    for pid in $(pgrep -x sunshine 2>/dev/null || true); do
        # Never kill this service script or its shell.
        if [ "${pid}" = "$$" ] || [ "${pid}" = "${PPID}" ]; then
            continue
        fi

        exe=$(readlink -f "/proc/${pid}/exe" 2>/dev/null || true)
        case "${exe}" in
            */bash|*/sh|"")
                continue
                ;;
        esac

        kill "${pid}" >/dev/null 2>&1 || true
    done
}

wait_for_drm() {
    local remaining=30
    while [ ! -d /dev/dri ] && [ "${remaining}" -gt 0 ]; do
        sleep 1
        remaining=$((remaining - 1))
    done
}

# Batocera starts user services from S99 while the compositor may still be coming up.
# Wayland builds (labwc): wait for the Wayland socket.
# X11 builds (openbox/Xorg): wait for the X11 socket only, do not burn 90s on Wayland.
prepare_display_env() {
    export DISPLAY="${DISPLAY:-:0}"

    if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
        if [ -d /run/user/0 ]; then
            export XDG_RUNTIME_DIR=/run/user/0
        else
            export XDG_RUNTIME_DIR=/run
        fi
    fi
}

expects_wayland() {
    # Batocera Wayland images ship labwc; X11 images typically do not.
    [ -x /etc/init.d/S14labwc ] && return 0
    [ -x /usr/bin/labwc ] && return 0
    return 1
}

wayland_socket_ready() {
    local socket display="${WAYLAND_DISPLAY:-wayland-0}"

    for socket in \
        "${XDG_RUNTIME_DIR}/${display}" \
        "/run/${display}" \
        "/run/user/0/${display}" \
        "/tmp/${display}"
    do
        if [ -S "${socket}" ]; then
            printf '%s\n' "${socket}"
            return 0
        fi
    done
    return 1
}

x11_socket_ready() {
    local socket

    for socket in /tmp/.X11-unix/X0 /tmp/.X11-unix/X1; do
        if [ -S "${socket}" ]; then
            printf '%s\n' "${socket}"
            return 0
        fi
    done
    return 1
}

wait_for_display() {
    local remaining socket=""

    prepare_display_env

    if expects_wayland; then
        export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
        remaining=90
        while [ "${remaining}" -gt 0 ]; do
            if socket=$(wayland_socket_ready); then
                log "Wayland is ready (${socket}, WAYLAND_DISPLAY=${WAYLAND_DISPLAY}, XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR})"
                return 0
            fi
            sleep 1
            remaining=$((remaining - 1))
        done
        log "WARNING: Wayland socket was not ready after 90s; launching anyway."
        return 1
    fi

    # X11-only Batocera: do not set WAYLAND_DISPLAY, and do not wait for Wayland.
    unset WAYLAND_DISPLAY || true
    remaining=60
    while [ "${remaining}" -gt 0 ]; do
        if socket=$(x11_socket_ready); then
            log "X11 is ready (${socket}, DISPLAY=${DISPLAY})"
            return 0
        fi
        sleep 1
        remaining=$((remaining - 1))
    done
    log "WARNING: X11 socket was not ready after 60s; launching anyway."
    return 1
}

start_sunshine() {
    exec >>"${LOG_FILE}" 2>&1
    log "Starting ${SERVICE_NAME}"

    if ! command -v flatpak >/dev/null 2>&1; then
        log "ERROR: Flatpak is not available."
        return 1
    fi

    if ! is_installed; then
        log "ERROR: Sunshine Flatpak is not installed system-wide (${APP_ID})."
        log "Install it from Batocera's Flatpak Manager first."
        return 1
    fi

    if is_running; then
        log "Sunshine is already running."
        return 0
    fi

    wait_for_drm
    wait_for_display || true
    log "Launching ${APP_ID} with DISPLAY=${DISPLAY} WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset} XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR}"
    flatpak run --system "${APP_ID}" &
    local launcher_pid=$!

    # Require the Web UI port, not only flatpak ps. Sunshine can appear in
    # flatpak ps during encoder probing and then exit before binding 47990.
    local remaining=20
    while [ "${remaining}" -gt 0 ]; do
        if port_in_use; then
            log "Sunshine started successfully."
            return 0
        fi
        if ! kill -0 "${launcher_pid}" 2>/dev/null && ! is_running; then
            break
        fi
        sleep 1
        remaining=$((remaining - 1))
    done

    if port_in_use; then
        log "Sunshine started successfully."
        return 0
    fi

    log "ERROR: Sunshine exited during startup or Web UI port ${WEB_UI_PORT} did not open. See ${LOG_FILE}"
    return 1
}

stop_sunshine() {
    exec >>"${LOG_FILE}" 2>&1
    log "Stopping ${SERVICE_NAME}"

    if ! is_running; then
        log "Sunshine is not running."
        return 0
    fi

    flatpak kill "${APP_ID}" >/dev/null 2>&1 || true

    local remaining=10
    while is_running && [ "${remaining}" -gt 0 ]; do
        sleep 1
        remaining=$((remaining - 1))
    done

    if is_running; then
        log "Flatpak kill did not clear Sunshine; forcing leftover processes to stop."
        kill_leftover_sunshine
        sleep 1
    fi

    remaining=5
    while is_running && [ "${remaining}" -gt 0 ]; do
        sleep 1
        remaining=$((remaining - 1))
    done

    if is_running; then
        log "ERROR: Sunshine did not stop cleanly."
        return 1
    fi

    log "Sunshine stopped."
}

case "${1:-}" in
    start) start_sunshine ;;
    stop) stop_sunshine ;;
    restart|reload)
        stop_sunshine || true
        sleep 1
        start_sunshine
        ;;
    status)
        if is_running; then
            echo "${SERVICE_NAME} is running"
            exit 0
        fi
        echo "${SERVICE_NAME} is stopped"
        exit 1
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload|status}"
        exit 1
        ;;
esac
